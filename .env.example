# Copy to .env and fill in keys you have. Everything is optional —
# missing keys fall back to mock data and the demo still runs end-to-end.

# Optional: live AI advisor (OpenAI gpt-4o-mini). Without this, a
# rules-based mock-advisor handles all questions using the same
# context format. Get a key at https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Optional: NASA FIRMS hotspots (live wildfire detections, last 24 h
# California-wide). Surfaces a HUD badge and AI advisor context.
# Free at https://firms.modaps.eosdis.nasa.gov/api/
FIRMS_MAP_KEY=

# Optional: US Census Bureau (real population data for the real-data
# swap-in path). Free at https://api.census.gov/data/key_signup.html
CENSUS_API_KEY=

# Set to 1 to skip Arduino auto-detection entirely.
DISABLE_ARDUINO=0

# Set to 1 to force AI / FIRMS to use mock fallbacks even if keys are
# present. Used by _e2e.js for hermetic testing; leave unset normally.
# MM_FORCE_MOCK=1

# Server port (defaults to 3000).
PORT=3000
