# Copy to .env and fill in keys you have. Everything is optional —
# missing keys fall back to mock data and the demo still runs end-to-end.

# Optional: live AI advisor (Gemini). Without this, a rules-based
# mock-advisor handles all questions using the same context format.
# Get a key at https://ai.google.dev
GEMINI_API_KEY=

# Optional: NASA FIRMS hotspots (live fire detections) — not currently
# wired into the demo; reserved for the stretch goal.
FIRMS_MAP_KEY=

# Set to 1 to skip Arduino auto-detection entirely.
DISABLE_ARDUINO=0

# Server port (defaults to 3000).
PORT=3000
